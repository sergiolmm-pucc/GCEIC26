# ============================================================
# SaunaCalc Elite — GitIgnore Oficial
# ============================================================

# Dependências de todas as pastas (API, App e E2E)
node_modules/
api/node_modules/
app/node_modules/
e2e-tests/node_modules/

# Relatórios de Testes e Cobertura do Jest
coverage/
api/coverage/
junit.xml
api/junit.xml

# Capturas de ecrã e relatórios dos testes funcionais (E2E)
e2e-tests/screenshots/
e2e-tests/reports/

# Ficheiros de Logs do Node/NPM
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/

# Configurações locais de IDEs (VS Code, WebStorm, etc.)
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# Ficheiros de Variáveis de Ambiente e Segredos (Segurança)
.env
.env.local
.env.test
.env.production

# Ficheiros do Sistema Operacional
.DS_Store
Thumbs.db