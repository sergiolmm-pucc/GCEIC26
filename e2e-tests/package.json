{
  "name": "e2e-tests",
  "version": "1.0.0",
  "description": "Testes E2E com Selenium WebDriver — GCEIC26",
  "scripts": {
    "test": "jest --testTimeout=60000 --forceExit",
    "test:simulacao": "jest tests/simulacao.test.js --testTimeout=60000 --forceExit",
    "test:capacidade": "jest tests/capacidade.test.js --testTimeout=60000 --forceExit"
  },
  "jest": {
    "testMatch": [
      "**/tests/simulacao.test.js",
      "**/tests/capacidade.test.js"
    ]
  },
  "dependencies": {
    "selenium-webdriver": "^4.43.0"
  },
  "devDependencies": {
    "jest": "^29.7.0"
  }
}
