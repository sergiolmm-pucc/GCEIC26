  <!-- SISTEMA DE RECALCULO EM TEMPO REAL E ABAS -->
  <script>
    // Gerenciador de Abas didáticas
    function switchTab(tabId) {
      document.querySelectorAll('.tab-button').forEach(btn => btn.classList.remove('active'));
      document.querySelectorAll('.tab-content').forEach(content => content.classList.remove('active'));
      
      const targetBtn = Array.from(document.querySelectorAll('.tab-button')).find(btn => btn.textContent.toLowerCase().includes(tabId));
      if (targetBtn) targetBtn.classList.add('active');
      
      const targetContent = document.getElementById(`tab-${tabId}`);
      if (targetContent) targetContent.classList.add('active');
    }

    // Estrutura global didática
    let globalValorHoraFinal = 0;
    let globalCustoHoraEquilibrio = 0;
    let globalValorHoraBase = 0;
    let globalPercentualImpostos = 0;
    let taskList = [];

    // Formatação BRL didática
    function formatCurrency(value) {
      return new Intl.NumberFormat('pt-BR', { style: 'currency', currency: 'BRL' }).format(value);
    }

    // CALCULO DIDATICO EM TEMPO REAL (Chamado ao digitar)
    async function calcularRealtime() {
      // Coleta
      const payload = {
        salarioDesejado: parseFloat(document.getElementById('salarioDesejado').value) || 0,
        diasTrabalhadosSemana: parseInt(document.getElementById('diasTrabalhadosSemana').value) || 5,
        horasTrabalhadasDia: parseFloat(document.getElementById('horasTrabalhadasDia').value) || 8,
        semanasFeriasAno: parseInt(document.getElementById('semanasFeriasAno').value) || 0,
        percentualProdutivo: parseFloat(document.getElementById('percentualProdutivo').value) || 100,
        despesasFixasMensais: parseFloat(document.getElementById('despesasFixasMensais').value) || 0,
        reservaSeguranca: parseFloat(document.getElementById('reservaSeguranca').value) || 0,
        margemLucroDesejada: parseFloat(document.getElementById('margemLucroDesejada').value) || 0,
        percentualImpostos: parseFloat(document.getElementById('percentualImpostos').value) || 0,
      };

      // Se valores mínimos estiverem vazios ou errados, ignora para não poluir
      if (payload.salarioDesejado <= 0 || payload.diasTrabalhadosSemana <= 0 || payload.horasTrabalhadasDia <= 0) {
        return;
      }

      try {
        const res = await fetch('/calcular', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        
        const json = await res.json();
        if (!json.success) return;

        const data = json.data;

        // Guarda variáveis didáticas globais
        globalValorHoraFinal = data.precoHoraFinal;
        globalCustoHoraEquilibrio = data.custoHoraEquilibrio;
        globalValorHoraBase = data.valorHoraBase;
        globalPercentualImpostos = payload.percentualImpostos;

        // Atualização da UI
        document.getElementById('precoHoraFinalText').textContent = formatCurrency(data.precoHoraFinal);
        document.getElementById('horasFaturaveisMesText').textContent = data.horasFaturaveisMes;
        document.getElementById('valorHoraBaseText').textContent = formatCurrency(data.valorHoraBase);
        document.getElementById('custoHoraEquilibrioText').textContent = formatCurrency(data.custoHoraEquilibrio);

        // Caixa
        document.getElementById('faturamentoMensalProjetadoText').textContent = formatCurrency(data.faturamentoMensalProjetado);
        document.getElementById('despesaMensalTotalText').textContent = '- ' + formatCurrency(data.despesaMensalTotal);
        document.getElementById('impostoMensalProjetadoText').textContent = '- ' + formatCurrency(data.impostoMensalProjetado);
        document.getElementById('custoMaoDeObraMensalText').textContent = '- ' + formatCurrency(data.custoMaoDeObraMensal);
        document.getElementById('lucroMensalLiquidoText').textContent = formatCurrency(data.lucroMensalLiquido);

        // Narrativa Didática Dinâmica
        const narrativeText = `Para garantir seu salário líquido pessoal de <strong>${formatCurrency(payload.salarioDesejado)}</strong> (com 13º e férias incluídos no custo mensal de <span class="highlight-1">${formatCurrency(data.custoMaoDeObraMensal)}</span>), pagar as despesas corporativas de <span class="highlight-2">${formatCurrency(data.despesaMensalTotal)}</span>, recolher impostos de <span class="highlight-4">${payload.percentualImpostos}%</span> sobre suas notas e manter uma margem de lucro de <strong>${payload.margemLucroDesejada}%</strong> para caixa da empresa, sua tarifa final recomendada é de <strong>${formatCurrency(data.precoHoraFinal)}/hora</strong> para um regime de <strong>${data.horasFaturaveisMes} horas</strong> faturáveis por mês.`;
        document.getElementById('didacticNarrative').innerHTML = narrativeText;

        // Gráfico stacked
        updateChart(data);
        
        // Simulador
        recalcTasks();

      } catch (e) {
        // Falhas silenciosas no tempo real para não atrapalhar a digitação do usuário
      }
    }

    // Atualiza barras SVG
    function updateChart(data) {
      const labor = data.valorHoraBase;
      const operac = data.custoOperacionalHora;
      const markup = data.precoHoraLimpo - data.custoHoraEquilibrio;
      const taxes = data.precoHoraFinal - data.precoHoraLimpo;
      const total = data.precoHoraFinal;

      const pctLabor = Math.max(0, (labor / total) * 100);
      const pctOverhead = Math.max(0, (operac / total) * 100);
      const pctProfit = Math.max(0, (markup / total) * 100);
      const pctTaxes = Math.max(0, (taxes / total) * 100);

      document.getElementById('barLabor').style.width = pctLabor + '%';
      document.getElementById('barOverhead').style.width = pctOverhead + '%';
      document.getElementById('barProfit').style.width = pctProfit + '%';
      document.getElementById('barTaxes').style.width = pctTaxes + '%';

      document.getElementById('pctLaborText').textContent = pctLabor.toFixed(1) + '%';
      document.getElementById('pctOverheadText').textContent = pctOverhead.toFixed(1) + '%';
      document.getElementById('pctProfitText').textContent = pctProfit.toFixed(1) + '%';
      document.getElementById('pctTaxesText').textContent = pctTaxes.toFixed(1) + '%';
    }

    // ==========================================================================
    // SIMULADOR DE TAREFAS DYNAMIC SCRIPTS
    // ==========================================================================
    function addTask() {
      if (globalValorHoraFinal === 0) {
        alert('Carregue os valores válidos primeiro na calculadora.');
        return;
      }

      const nameInput = document.getElementById('taskName');
      const hoursInput = document.getElementById('taskHours');

      const name = nameInput.value.trim() || 'Tarefa Estimada';
      const hours = parseFloat(hoursInput.value);

      if (isNaN(hours) || hours <= 0) {
        alert('Forneça a estimativa de horas.');
        return;
      }

      taskList.push({ id: Date.now(), name, hours });
      nameInput.value = '';
      hoursInput.value = '10';

      recalcTasks();
    }

    function removeTask(id) {
      taskList = taskList.filter(t => t.id !== id);
      recalcTasks();
    }

    function recalcTasks() {
      const tbody = document.getElementById('taskTableBody');
      tbody.innerHTML = '';

      if (taskList.length === 0) {
        tbody.innerHTML = `
          <tr>
            <td colspan="7" class="sim-empty">Nenhuma tarefa simulada ainda. Digite tarefas acima para começar a estimar custos!</td>
          </tr>
        `;
        return;
      }

      taskList.forEach(task => {
        const custoMaoObra = task.hours * globalValorHoraBase;
        const custoEquilibrio = task.hours * globalCustoHoraEquilibrio;
        const precoFinal = task.hours * globalValorHoraFinal;
        
        const imposto = precoFinal * (globalPercentualImpostos / 100);
        const lucroLiquido = precoFinal - custoEquilibrio - imposto;

        const tr = document.createElement('tr');
        tr.innerHTML = `
          <td><strong>${task.name}</strong></td>
          <td>${task.hours}h</td>
          <td>${formatCurrency(custoMaoObra)}</td>
          <td>${formatCurrency(custoEquilibrio)}</td>
          <td style="color: var(--accent-3); font-weight: bold;">${formatCurrency(precoFinal)}</td>
          <td style="color: var(--accent-2); font-weight: bold;">${formatCurrency(lucroLiquido)}</td>
          <td>
            <button class="btn-delete-task" onclick="removeTask(${task.id})">Remover</button>
          </td>
        `;
        tbody.appendChild(tr);
      });
    }

    // Inicialização didática
    window.addEventListener('DOMContentLoaded', () => {
      calcularRealtime();
    });
  </script>
</body>
</html>