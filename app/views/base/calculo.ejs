<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>HourlyCost — Dashboard Didático</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;700;800&family=Space+Mono:wght@400;700&family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg: #000000; /* Preto Puro */
      --surface: rgba(9, 9, 11, 0.7); /* Zinc 950 com opacidade */
      --surface-card: rgba(24, 24, 27, 0.75); /* Zinc 900 com opacidade */
      --border: rgba(255, 255, 255, 0.08);
      --text: #fafafa; /* Zinc 50 */
      --muted: #71717a; /* Zinc 500 */
      
      /* Monochrome Grayscale Palette */
      --accent-1: #ffffff; /* Branco Puro (Ana Carolina) */
      --accent-1-glow: rgba(255, 255, 255, 0.05);
      
      --accent-2: #e4e4e7; /* Zinc 200 (Bruno Eduardo) */
      --accent-2-glow: rgba(228, 228, 231, 0.05);
      
      --accent-3: #a1a1aa; /* Zinc 400 (Carlos Augusto) */
      --accent-3-glow: rgba(161, 161, 170, 0.05);
      
      --accent-4: #3f3f46; /* Zinc 700 (Impostos) */
      --accent-4-glow: rgba(63, 63, 70, 0.05);

      --glass-blur: 20px;
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      background-color: var(--bg);
      color: var(--text);
      font-family: 'Outfit', sans-serif;
      min-height: 100vh;
      overflow-x: hidden;
      position: relative;
    }

    /* Grid de background didático sutil branco */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image:
        linear-gradient(rgba(255, 255, 255, 0.02) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255, 255, 255, 0.02) 1px, transparent 1px);
      background-size: 30px 30px;
      pointer-events: none;
      z-index: 0;
    }

    /* Brilhos orbitais - Ocultados no Monocromático */
    .glow-sphere {
      display: none;
    }

    /* ==========================================================================
       NAVBAR
       ========================================================================== */
    nav {
      position: relative;
      z-index: 10;
      padding: 20px 40px;
      background: rgba(3, 3, 8, 0.85);
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      border-bottom: 1px solid var(--border);
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .nav-logo {
      font-family: 'Syne', sans-serif;
      font-size: 22px;
      font-weight: 800;
      letter-spacing: -1px;
      color: #fff;
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .nav-logo span {
      color: #ffffff;
    }

    .nav-user {
      display: flex;
      align-items: center;
      gap: 16px;
      font-size: 14px;
    }

    .nav-user strong {
      color: #ffffff;
    }

    .btn-logout {
      background: transparent;
      border: 1px solid rgba(255, 255, 255, 0.15);
      color: var(--text);
      padding: 8px 16px;
      border-radius: 8px;
      text-decoration: none;
      font-size: 12px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      transition: all 0.3s;
    }

    .btn-logout:hover {
      background: #ffffff;
      color: #000000;
      border-color: #ffffff;
      box-shadow: 0 0 15px rgba(255, 255, 255, 0.15);
    }

    /* ==========================================================================
       TABS DIDÁTICAS
       ========================================================================== */
    .main-wrapper {
      max-width: 1400px;
      margin: 30px auto 0;
      padding: 0 40px;
      position: relative;
      z-index: 5;
    }

    .tabs-header {
      display: flex;
      gap: 8px;
      border-bottom: 1px solid var(--border);
      padding-bottom: 1px;
      margin-bottom: 30px;
    }

    .tab-button {
      background: transparent;
      border: none;
      color: var(--muted);
      font-family: inherit;
      font-size: 13px;
      font-weight: 700;
      letter-spacing: 1px;
      text-transform: uppercase;
      padding: 14px 28px;
      cursor: pointer;
      transition: all 0.3s;
      position: relative;
    }

    .tab-button:hover {
      color: #fff;
    }

    .tab-button.active {
      color: #fff;
    }

    .tab-button.active::after {
      content: '';
      position: absolute;
      bottom: -1px;
      left: 0;
      right: 0;
      height: 3px;
      background: #ffffff;
      border-radius: 3px 3px 0 0;
    }

    .tab-content {
      display: none;
      animation: fadeIn 0.4s ease;
    }

    .tab-content.active {
      display: block;
    }

    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(12px); }
      to { opacity: 1; transform: translateY(0); }
    }

    /* ==========================================================================
       PROGRESS WORKFLOW (MÓDULO DE APRENDIZADO)
       ========================================================================== */
    .flow-steps {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
      margin-bottom: 30px;
    }

    @media (max-width: 900px) {
      .flow-steps {
        grid-template-columns: 1fr;
      }
    }

    .step-node {
      background: var(--surface-card);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 16px 20px;
      display: flex;
      align-items: center;
      gap: 14px;
      position: relative;
    }

    .step-number {
      width: 32px;
      height: 32px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: bold;
      font-size: 14px;
      flex-shrink: 0;
    }

    .step-1-node { border-left: 3px solid var(--accent-1); }
    .step-1-node .step-number { background: var(--accent-1-glow); color: var(--accent-1); }
    
    .step-2-node { border-left: 3px solid var(--accent-2); }
    .step-2-node .step-number { background: var(--accent-2-glow); color: var(--accent-2); }
    
    .step-3-node { border-left: 3px solid var(--accent-3); }
    .step-3-node .step-number { background: var(--accent-3-glow); color: var(--accent-3); }

    .step-info {
      font-size: 12px;
    }

    .step-title {
      font-weight: 700;
      color: #fff;
      font-size: 13px;
      margin-bottom: 2px;
    }

    .step-author {
      color: var(--muted);
      font-size: 10px;
      font-family: 'Space Mono', monospace;
    }

    /* ==========================================================================
       DASHBOARD GRID
       ========================================================================== */
    .dashboard-grid {
      display: grid;
      grid-template-columns: 1.15fr 0.85fr;
      gap: 30px;
      align-items: start;
    }

    @media (max-width: 1024px) {
      .dashboard-grid {
        grid-template-columns: 1fr;
      }
    }

    .card {
      background: var(--surface);
      backdrop-filter: blur(var(--glass-blur));
      -webkit-backdrop-filter: blur(var(--glass-blur));
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 30px;
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.4);
      margin-bottom: 30px;
      position: relative;
    }

    .card-title {
      font-family: 'Syne', sans-serif;
      font-size: 20px;
      font-weight: 700;
      margin-bottom: 20px;
      display: flex;
      align-items: center;
      gap: 10px;
      border-bottom: 1px solid rgba(255,255,255,0.04);
      padding-bottom: 12px;
    }

    .card-title .author-badge {
      font-family: 'Space Mono', monospace;
      font-size: 9px;
      background: rgba(255, 255, 255, 0.05);
      border: 1px solid var(--border);
      padding: 3px 8px;
      border-radius: 4px;
      margin-left: auto;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    /* didático explanatory descriptions */
    .helper-text {
      background: rgba(255, 255, 255, 0.02);
      border-left: 2px solid rgba(255, 255, 255, 0.1);
      padding: 8px 12px;
      font-size: 12px;
      color: var(--muted);
      border-radius: 0 6px 6px 0;
      margin-top: 6px;
      line-height: 1.5;
    }

    /* Form Fields */
    .form-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
      margin-bottom: 16px;
    }

    @media (max-width: 600px) {
      .form-row {
        grid-template-columns: 1fr;
      }
    }

    .input-group {
      margin-bottom: 20px;
    }

    .input-group label {
      display: block;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.8px;
      color: var(--text);
      text-transform: uppercase;
      margin-bottom: 8px;
    }

    .input-group input {
      width: 100%;
      background: rgba(255, 255, 255, 0.03);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 12px 14px;
      color: #fff;
      font-size: 14px;
      font-family: inherit;
      outline: none;
      transition: all 0.3s;
    }

    /* Focus indicators didáticos */
    .ana-group input:focus { border-color: #ffffff; box-shadow: 0 0 10px rgba(255, 255, 255, 0.05); background: rgba(255, 255, 255, 0.01); }
    .bruno-group input:focus { border-color: #ffffff; box-shadow: 0 0 10px rgba(255, 255, 255, 0.05); background: rgba(255, 255, 255, 0.01); }
    .carlos-group input:focus { border-color: #ffffff; box-shadow: 0 0 10px rgba(255, 255, 255, 0.05); background: rgba(255, 255, 255, 0.01); }

    /* ==========================================================================
       DIDACTIC LIVE REPORT CARD (DIREITA)
       ========================================================================== */
    .sticky-panel {
      position: sticky;
      top: 20px;
    }

    .result-card {
      background: var(--surface-card);
      border: 1px solid var(--border);
      box-shadow: 0 12px 40px rgba(0, 0, 0, 0.5);
      position: relative;
    }

    .result-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0; height: 3px;
      background: #ffffff;
      border-radius: 3px 3px 0 0;
    }

    .result-hero {
      text-align: center;
      padding: 24px;
      background: rgba(255, 255, 255, 0.02);
      border-radius: 12px;
      border: 1px dashed var(--border);
      margin-bottom: 24px;
    }

    .hero-label {
      font-size: 11px;
      letter-spacing: 2px;
      color: var(--muted);
      text-transform: uppercase;
      margin-bottom: 6px;
    }

    .hero-value {
      font-family: 'Syne', sans-serif;
      font-size: 54px;
      font-weight: 800;
      line-height: 1;
      color: #ffffff;
      margin-bottom: 8px;
    }

    /* DINAMIC EXPLICATORY STATEMENT BOX */
    .didactic-narrative {
      background: rgba(255, 255, 255, 0.02);
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 12px;
      padding: 16px;
      font-size: 13.5px;
      line-height: 1.6;
      color: #fafafa;
      margin-bottom: 24px;
    }

    .didactic-narrative strong {
      color: var(--accent-3);
      font-weight: 700;
    }
    .didactic-narrative .highlight-1 { color: var(--accent-1); }
    .didactic-narrative .highlight-2 { color: var(--accent-2); }
    .didactic-narrative .highlight-4 { color: var(--accent-4); }

    .live-status-pill {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 6px 14px;
      background: var(--accent-1-glow);
      border: 1px solid rgba(192, 132, 252, 0.3);
      color: var(--accent-1);
      border-radius: 20px;
      font-size: 12px;
      font-weight: 600;
      margin-bottom: 24px;
    }

    /* Sub-valores */
    .breakdown-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
      margin-bottom: 24px;
    }

    .breakdown-item {
      background: rgba(255,255,255,0.01);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 12px;
    }

    .breakdown-label {
      font-size: 10px;
      letter-spacing: 0.5px;
      color: var(--muted);
      text-transform: uppercase;
      margin-bottom: 4px;
    }

    .breakdown-val {
      font-size: 16px;
      font-weight: 700;
      color: #fff;
    }

    /* Progress bar horizontal empilhada */
    .stacked-bar-wrapper {
      margin-bottom: 24px;
    }

    .stacked-bar-label {
      font-size: 11px;
      letter-spacing: 0.5px;
      color: var(--muted);
      text-transform: uppercase;
      margin-bottom: 8px;
    }

    .bar-track {
      height: 18px;
      width: 100%;
      border-radius: 9px;
      overflow: hidden;
      display: flex;
      background: rgba(255,255,255,0.03);
    }

    .bar-seg {
      height: 100%;
      transition: width 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .seg-ana { background-color: var(--accent-1); }
    .seg-bruno { background-color: var(--accent-2); }
    .seg-carlos { background-color: var(--accent-3); }
    .seg-tax { background-color: var(--accent-4); }

    .bar-legend {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 8px;
      font-size: 11px;
      margin-top: 10px;
    }

    .legend-item {
      display: flex;
      align-items: center;
      gap: 6px;
    }

    .legend-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
    }

    /* Cashflow Table */
    .projection-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 13px;
      margin-top: 10px;
    }

    .projection-table tr {
      border-bottom: 1px solid rgba(255,255,255,0.03);
    }
    .projection-table tr:last-child {
      border-bottom: none;
    }

    .projection-table td {
      padding: 10px 0;
    }

    .projection-table td:last-child {
      text-align: right;
      font-weight: 600;
    }

    /* ==========================================================================
       SIMULADOR DE TAREFAS
       ========================================================================== */
    .simulator-card {
      border-left: 4px solid var(--accent-3);
    }

    .sim-form {
      display: grid;
      grid-template-columns: 2fr 1fr auto;
      gap: 16px;
      margin-bottom: 20px;
    }

    @media (max-width: 600px) {
      .sim-form {
        grid-template-columns: 1fr;
      }
    }

    .btn-add-task {
      background: var(--accent-3);
      color: #030308;
      border: none;
      border-radius: 8px;
      padding: 0 20px;
      font-size: 13px;
      font-weight: 700;
      letter-spacing: 0.5px;
      text-transform: uppercase;
      cursor: pointer;
      height: 44px;
      transition: all 0.3s;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .btn-add-task:hover {
      background: #80f5ff;
      box-shadow: 0 0 15px rgba(34, 211, 238, 0.4);
      transform: translateY(-1px);
    }

    .sim-table-container {
      max-height: 250px;
      overflow-y: auto;
      border: 1px solid var(--border);
      border-radius: 10px;
      background: rgba(0,0,0,0.15);
    }

    .sim-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 13px;
      text-align: left;
    }

    .sim-table th, .sim-table td {
      padding: 12px 16px;
      border-bottom: 1px solid var(--border);
    }

    .sim-table th {
      background: rgba(255,255,255,0.02);
      font-weight: 700;
      color: var(--muted);
      text-transform: uppercase;
      font-size: 10px;
      letter-spacing: 0.8px;
    }

    .sim-table tr:last-child td {
      border-bottom: none;
    }

    .btn-delete-task {
      background: transparent;
      border: 1px solid rgba(255, 255, 255, 0.15);
      color: var(--text);
      cursor: pointer;
      font-size: 11px;
      padding: 4px 8px;
      border-radius: 4px;
      transition: all 0.2s;
      font-family: inherit;
    }
    .btn-delete-task:hover {
      background: #ffffff;
      color: #09090b;
      border-color: #ffffff;
    }

    .sim-empty {
      padding: 40px;
      text-align: center;
      color: var(--muted);
      font-style: italic;
    }

    /* ==========================================================================
       EQUIPE VIEW (TAB 2)
       ========================================================================== */
    .team-container {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 30px;
      max-width: 1200px;
      margin: 0 auto;
    }

    @media (max-width: 900px) {
      .team-container {
        grid-template-columns: 1fr;
      }
    }

    .member-card {
      background: var(--surface-card);
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 40px 30px;
      text-align: center;
      transition: all 0.3s;
      position: relative;
      overflow: hidden;
    }

    .member-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0; width: 100%; height: 4px;
    }
    .mem-1::before { background: var(--accent-1); }
    .mem-2::before { background: var(--accent-2); }
    .mem-3::before { background: var(--accent-3); }

    .member-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 15px 35px rgba(0,0,0,0.5);
      border-color: rgba(255,255,255,0.15);
    }

    .member-avatar {
      width: 90px;
      height: 90px;
      border-radius: 50%;
      margin: 0 auto 24px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 36px;
      border: 2px solid var(--border);
      box-shadow: 0 8px 20px rgba(0,0,0,0.3);
    }
    .mem-1 .member-avatar { background: var(--accent-1-glow); border-color: var(--accent-1); }
    .mem-2 .member-avatar { background: var(--accent-2-glow); border-color: var(--accent-2); }
    .mem-3 .member-avatar { background: var(--accent-3-glow); border-color: var(--accent-3); }

    .member-name {
      font-family: 'Syne', sans-serif;
      font-size: 20px;
      font-weight: 700;
      margin-bottom: 6px;
    }

    .member-role {
      font-family: 'Space Mono', monospace;
      font-size: 11px;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 1px;
      margin-bottom: 20px;
    }

    .member-desc {
      font-size: 13.5px;
      line-height: 1.6;
      color: #d1d5db;
      border-top: 1px solid rgba(255,255,255,0.04);
      padding-top: 20px;
    }

    /* ==========================================================================
       AJUDA VIEW (TAB 3)
       ========================================================================== */
    .help-box {
      max-width: 900px;
      margin: 0 auto;
    }

    .help-block {
      margin-bottom: 40px;
    }

    .help-block h3 {
      font-family: 'Syne', sans-serif;
      font-size: 18px;
      font-weight: 700;
      color: #fff;
      margin-bottom: 14px;
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .help-block h3 span {
      color: var(--accent-3);
    }

    .help-block p {
      font-size: 14px;
      line-height: 1.6;
      color: #d1d5db;
      margin-bottom: 12px;
    }

    .equation {
      background: rgba(0,0,0,0.3);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 16px;
      font-family: 'Space Mono', monospace;
      font-size: 13px;
      color: var(--accent-3);
      margin: 16px 0;
      overflow-x: auto;
    }

    /* FOOTER */
    footer {
      text-align: center;
      padding: 40px;
      border-top: 1px solid var(--border);
      color: var(--muted);
      font-family: 'Space Mono', monospace;
      font-size: 11px;
      letter-spacing: 2px;
      position: relative;
      z-index: 5;
      margin-top: 50px;
    }
  </style>
</head>
<body>

  <!-- Orbitas fluorescentes -->
  <div class="glow-sphere glow-1"></div>
  <div class="glow-sphere glow-2"></div>

  <!-- NAVBAR -->
  <nav>
    <div class="nav-logo">
      <span>HourlyCost</span>
    </div>
    <div class="nav-user">
      <span>Profissional: <strong><%= user.nome %></strong></span>
      <a href="/logout" class="btn-logout">Sair</a>
    </div>
  </nav>

  <!-- CONTEÚDO PRINCIPAL WRAPPER -->
  <div class="main-wrapper">
    
    <!-- CABEÇALHO DAS ABAS -->
    <div class="tabs-header">
      <button class="tab-button active" onclick="switchTab('calculadora')">Calculadora de Custo/Preço</button>
      <button class="tab-button" onclick="switchTab('equipe')">Sobre a Equipe</button>
      <button class="tab-button" onclick="switchTab('ajuda')">Como Funciona (Didático)</button>
    </div>

    <!-- ==========================================================================
         ABA 1: CALCULADORA DIDÁTICA E DINÂMICA
         ========================================================================== -->
    <div id="tab-calculadora" class="tab-content active">
      
      <!-- Linha do Tempo/Etapas didática em progresso -->
      <div class="flow-steps">
        <div class="step-node step-1-node">
          <div class="step-number">1</div>
          <div class="step-info">
            <div class="step-title">Mão de Obra e Encargos</div>
            <div class="step-author">Por Ana Carolina</div>
          </div>
        </div>
        <div class="step-node step-2-node">
          <div class="step-number">2</div>
          <div class="step-info">
            <div class="step-title">Custos Operacionais e Ponto de Equilíbrio</div>
            <div class="step-author">Por Bruno Eduardo</div>
          </div>
        </div>
        <div class="step-node step-3-node">
          <div class="step-number">3</div>
          <div class="step-info">
            <div class="step-title">Markup e Imposto por Dentro</div>
            <div class="step-author">Por Carlos Augusto</div>
          </div>
        </div>
      </div>

      <div class="dashboard-grid">
        
        <!-- Formulário Dinâmico (Esquerda) -->
        <div>
          
          <!-- Passo 1 (Ana Carolina) -->
          <div class="card ana-group">
            <div class="card-title">
              <span>Mão de Obra e Disponibilidade Líquida</span>
