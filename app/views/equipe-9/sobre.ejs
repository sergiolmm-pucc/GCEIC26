  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Segoe UI', sans-serif; background: #f0f4f8; color: #333; }
    nav {
      background: #1a237e; color: white; padding: 14px 28px;
      display: flex; justify-content: space-between; align-items: center;
    }
    nav a { color: white; text-decoration: none; font-size: 0.9rem; opacity: 0.85; }
    nav a:hover { opacity: 1; }
    .container { max-width: 800px; margin: 40px auto; padding: 0 20px; }
    h2 { font-size: 1.8rem; color: #1a237e; margin-bottom: 8px; }
    .subtitle { color: #666; margin-bottom: 32px; font-size: 0.95rem; }
    .card {
      background: white; border-radius: 12px;
      padding: 28px; margin-bottom: 24px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.08);
    }
    .card h3 { font-size: 1.1rem; color: #1a237e; margin-bottom: 16px; border-bottom: 2px solid #e8eaf6; padding-bottom: 10px; }
    .team-grid { display: flex; flex-wrap: wrap; gap: 20px; }
    .member {
      flex: 1; min-width: 180px; text-align: center; padding: 20px;
      background: #f5f7ff; border-radius: 10px; border: 1px solid #e8eaf6;
    }
    .avatar {
      width: 72px; height: 72px; border-radius: 50%;
      background: linear-gradient(135deg, #1a237e, #1565c0);
      display: flex; align-items: center; justify-content: center;
      font-size: 1.8rem; margin: 0 auto 12px;
    }
    .member strong { display: block; color: #1a237e; margin-bottom: 4px; }
    .member span { font-size: 0.82rem; color: #888; }
    .info-list { list-style: none; }
    .info-list li { padding: 8px 0; border-bottom: 1px solid #f0f4f8; font-size: 0.9rem; display: flex; gap: 8px; }
    .info-list li:last-child { border: none; }
    .badge {
      display: inline-block; background: #e8eaf6; color: #1a237e;
      padding: 3px 10px; border-radius: 20px; font-size: 0.8rem; font-weight: 600;
    }
