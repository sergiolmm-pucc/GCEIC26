<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Calculo Inverso de NF</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Segoe UI', sans-serif; background: #f0f4f8; color: #333; }
    nav {
      background: #1a237e; color: white; padding: 14px 28px;
      display: flex; justify-content: space-between; align-items: center;
    }
    nav a { color: white; text-decoration: none; font-size: 0.9rem; opacity: 0.85; }
    nav a:hover { opacity: 1; }
    .container { max-width: 700px; margin: 36px auto; padding: 0 20px; }
    h2 { font-size: 1.6rem; color: #1a237e; margin-bottom: 6px; }
    .subtitle { color: #666; font-size: 0.9rem; margin-bottom: 20px; }
    .info-box {
      background: #e8eaf6; border-left: 4px solid #1a237e; border-radius: 4px;
      padding: 12px 16px; font-size: 0.88rem; color: #1a237e; margin-bottom: 24px;
    }
    .card { background: white; border-radius: 12px; padding: 28px; box-shadow: 0 2px 8px rgba(0,0,0,0.08); margin-bottom: 20px; }
    .card h3 { font-size: 1rem; color: #1a237e; margin-bottom: 18px; }
    .field { margin-bottom: 16px; }
    label { display: block; font-size: 0.85rem; font-weight: 600; color: #555; margin-bottom: 6px; }
    input[type=number] {
      width: 100%; padding: 10px 14px; border: 1.5px solid #dde;
      border-radius: 8px; font-size: 0.95rem;
    }
    input[type=number]:focus { outline: none; border-color: #1a237e; }
    .grid2 { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
    .btn-padrao {
      background: #e8eaf6; color: #1a237e; border: none; border-radius: 8px;
      padding: 9px 16px; font-size: 0.85rem; font-weight: 600; cursor: pointer; margin-bottom: 20px;
    }
    .btn-calcular {
      width: 100%; padding: 13px; background: #1a237e; color: white;
      border: none; border-radius: 8px; font-size: 1rem; font-weight: 600; cursor: pointer;
    }
    .btn-calcular:disabled { background: #9fa8da; cursor: not-allowed; }
    .resultado { display: none; }
    .resultado.visivel { display: block; }
    .resultado-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 16px; }
    .resultado-item { background: #f5f7ff; border-radius: 10px; padding: 16px; text-align: center; border: 1px solid #e8eaf6; }
    .resultado-item .label { font-size: 0.78rem; color: #888; margin-bottom: 4px; }
    .resultado-item .valor { font-size: 1.15rem; font-weight: 700; color: #1a237e; }
    .destaque { background: #1a237e; color: white; border-radius: 10px; padding: 20px; text-align: center; }
    .destaque .label { font-size: 0.85rem; opacity: 0.8; margin-bottom: 4px; }
    .destaque .valor { font-size: 2rem; font-weight: 700; }
    .erro-box { background: #fef2f2; border: 1px solid #fca5a5; color: #b91c1c; border-radius: 8px; padding: 12px 16px; font-size: 0.88rem; display: none; margin-top: 12px; }
  </style>
</head>
<body>

<nav>
  <span style="font-weight:600">Calculo de NF</span>
  <div style="display:flex;gap:20px">
    <a href="/equipe-9/calculo">Calcular NF</a>
    <a href="/equipe-9/comparar">Comparar Alíquotas</a>
    <a href="/equipe-9/sobre">Sobre</a>
    <a href="/equipe-9/help">Ajuda</a>
    <a href="/equipe-9/logout">Sair</a>
  </div>
</nav>

<div class="container">
  <h2>Calculo Inverso de NF</h2>
  <p class="subtitle">Informe o valor total da nota e descubra qual era o valor original do produto.</p>

  <div class="card">
    <h3>Dados da Nota</h3>

    <button class="btn-padrao" onclick="usarPadrao()">Usar alíquotas padrao</button>

    <div class="field">
      <label for="totalNF">Total da Nota Fiscal (R$)</label>
      <input type="number" id="totalNF" placeholder="Ex: 1322,50" min="0.01" step="0.01">
    </div>

    <div class="grid2">
      <div class="field">
        <label for="icms">ICMS (%)</label>
        <input type="number" id="icms" placeholder="18" min="0" step="0.01">
      </div>
      <div class="field">
        <label for="ipi">IPI (%)</label>
        <input type="number" id="ipi" placeholder="5" min="0" step="0.01">
      </div>
      <div class="field">
        <label for="pis">PIS (%)</label>
        <input type="number" id="pis" placeholder="1.65" min="0" step="0.01">
      </div>
      <div class="field">
        <label for="cofins">COFINS (%)</label>
        <input type="number" id="cofins" placeholder="7.6" min="0" step="0.01">
      </div>
    </div>

    <button class="btn-calcular" id="btnCalcular" onclick="calcular()">Calcular Valor Original</button>
    <div class="erro-box" id="erroBox"></div>
  </div>

  <div class="card resultado" id="resultado">
    <h3>Resultado</h3>
    <div class="resultado-grid">
      <div class="resultado-item">
        <div class="label">ICMS descontado</div>
        <div class="valor" id="valorICMS">-</div>
      </div>
      <div class="resultado-item">
        <div class="label">IPI descontado</div>
        <div class="valor" id="valorIPI">-</div>
      </div>
      <div class="resultado-item">
        <div class="label">PIS descontado</div>
        <div class="valor" id="valorPIS">-</div>
      </div>
      <div class="resultado-item">
        <div class="label">COFINS descontado</div>
        <div class="valor" id="valorCOFINS">-</div>
      </div>
    </div>
    <div class="destaque">
      <div class="label">VALOR DO PRODUTO SEM IMPOSTOS</div>
      <div class="valor" id="valorProduto">-</div>
    </div>
  </div>
</div>

<script>
function fmt(v) { return v.toFixed(2); }

function usarPadrao() {
  document.getElementById('icms').value   = '18';
  document.getElementById('ipi').value    = '5';
  document.getElementById('pis').value    = '1.65';
  document.getElementById('cofins').value = '7.6';
}

async function calcular() {
  const btn  = document.getElementById('btnCalcular');
  const erro = document.getElementById('erroBox');
  const res  = document.getElementById('resultado');

  erro.style.display = 'none';
  res.classList.remove('visivel');

  const totalNF = parseFloat(document.getElementById('totalNF').value);
  const icms    = parseFloat(document.getElementById('icms').value)   || 0;
  const ipi     = parseFloat(document.getElementById('ipi').value)    || 0;
  const pis     = parseFloat(document.getElementById('pis').value)    || 0;
  const cofins  = parseFloat(document.getElementById('cofins').value) || 0;

  if (!totalNF || isNaN(totalNF)) {
    erro.textContent = 'Informe o total da nota fiscal.';
    erro.style.display = 'block';
    return;
  }

  btn.disabled = true;
  btn.textContent = 'Calculando...';

  try {
    const response = await fetch('/equipe-9/calcular-inverso', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ totalNF, icms, ipi, pis, cofins }),
    });

    const json = await response.json();

    if (!json.success) {
      erro.textContent = json.error;
      erro.style.display = 'block';
      return;
    }

    const d = json.data;
    document.getElementById('valorICMS').textContent    = fmt(d.valorICMS);
    document.getElementById('valorIPI').textContent     = fmt(d.valorIPI);
    document.getElementById('valorPIS').textContent     = fmt(d.valorPIS);
    document.getElementById('valorCOFINS').textContent  = fmt(d.valorCOFINS);
    document.getElementById('valorProduto').textContent = fmt(d.valorProduto);

    res.classList.add('visivel');

  } catch (e) {
    erro.textContent = 'Erro ao comunicar com o servidor: ' + e.message;
    erro.style.display = 'block';
  } finally {
    btn.disabled = false;
    btn.textContent = 'Calcular Valor Original';
  }
}
</script>

</body>
</html>