<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <title>Calculadora - <%= tipo %></title>
  <style>
    .form-group { margin-bottom: 15px; }
    .form-group label { display: block; margin-bottom: 5px; font-weight: bold; }
    .form-group input, .form-group select { width: 100%; padding: 10px; border: 1px solid #cbd5e1; border-radius: 6px; box-sizing: border-box; }
    .btn-calc { padding: 12px 24px; background-color: #10b981; color: white; border: none; border-radius: 6px; cursor: pointer; font-size: 16px; }
    .btn-calc:hover { background-color: #059669; }
    .result-box { margin-top: 30px; padding: 20px; background-color: #dcfce7; border-left: 5px solid #22c55e; display: none; }
    .error-box { margin-top: 30px; padding: 20px; background-color: #fee2e2; border-left: 5px solid #ef4444; display: none; color: #b91c1c; }
  </style>
</head>
<body>
  <%- include('partials/header') %>
  
  <div class="container">
    <h1 style="text-transform: capitalize;">Cálculo de <%= tipo %></h1>
    
    <form id="calcForm" onsubmit="realizarCalculo(event)">
      
      <% if (tipo === 'volume') { %>
        <div class="form-group">
          <label>Largura (m)</label>
          <input type="number" id="largura" required min="0" step="0.01">
        </div>
        <div class="form-group">
          <label>Comprimento (m)</label>
          <input type="number" id="comprimento" required min="0" step="0.01">
        </div>
        <div class="form-group">
          <label>Profundidade (m)</label>
          <input type="number" id="profundidade" required min="0" step="0.01">
        </div>
      <% } else if (tipo === 'agua') { %>
        <div class="form-group">
          <label>Volume (m³)</label>
          <input type="number" id="volumeMetrosCubicos" required min="0" step="0.01">
        </div>
        <div class="form-group">
          <label>Preço por m³ (R$)</label>
          <input type="number" id="precoMetroCubico" required min="0" step="0.01">
        </div>
      <% } else if (tipo === 'materiais') { %>
        <div class="form-group">
          <label>Volume (m³)</label>
          <input type="number" id="volume" required min="0" step="0.01">
        </div>
        <div class="form-group">
          <label>Tipo de Acabamento</label>
          <select id="tipoAcabamento" required>
            <option value="vinil">Vinil</option>
            <option value="fibra">Fibra</option>
            <option value="alvenaria">Alvenaria</option>
          </select>
        </div>
      <% } else if (tipo === 'manutencao') { %>
        <div class="form-group">
          <label>Volume (m³)</label>
          <input type="number" id="volume" required min="0" step="0.01">
        </div>
        <div class="form-group">
          <label>Meses</label>
          <input type="number" id="meses" required min="1" step="1">
        </div>
      <% } else if (tipo === 'mao-de-obra') { %>
        <div class="form-group">
          <label>Dias Estimados</label>
          <input type="number" id="diasEstimados" required min="1" step="1">
        </div>
        <div class="form-group">
          <label>Trabalhadores</label>
          <input type="number" id="trabalhadores" required min="1" step="1">
        </div>
        <div class="form-group">
          <label>Valor da Diária (R$)</label>
          <input type="number" id="valorDiaria" required min="0" step="0.01">
        </div>
      <% } %>

      <button type="submit" class="btn-calc">Calcular via API</button>
    </form>

    <div id="resultado" class="result-box"></div>
    <div id="erro" class="error-box"></div>

  </div>

  <script>
    async function realizarCalculo(event) {
      event.preventDefault();
      
      const tipo = '<%= tipo %>';
      const inputs = document.querySelectorAll('#calcForm input, #calcForm select');
      const bodyData = {};
      
      inputs.forEach(input => {
        if(input.id) {
          bodyData[input.id] = input.type === 'number' ? Number(input.value) : input.value;
        }
      });

      const resBox = document.getElementById('resultado');
      const errBox = document.getElementById('erro');
      resBox.style.display = 'none';
      errBox.style.display = 'none';

      try {
        const response = await fetch(`/api/calcular/${tipo}`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(bodyData)
        });
        
        const data = await response.json();
        
        if (data.success) {
          resBox.style.display = 'block';
          resBox.innerHTML = `<strong>Resultado:</strong><br><pre>${JSON.stringify(data.data, null, 2)}</pre>`;
        } else {
          errBox.style.display = 'block';
          errBox.innerText = `Erro: ${data.error}`;
        }
      } catch (err) {
        errBox.style.display = 'block';
        errBox.innerText = `Erro de conexão: ${err.message}`;
      }
    }
  </script>
</body>
</html>
