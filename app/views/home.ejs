<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>FINV – Home</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <div class="topbar">
    <span class="logo">FINV</span>
    <a class="btn-sair" href="/logout">Sair</a>
  </div>

  <div class="home-header">
    <h2 class="home-titulo">Bem-vindo! 👋</h2>
    <p class="home-sub">Simulador de Financiamento de Veículos</p>
  </div>

  <div class="grid">
    <a class="menu-card" href="/simulador">
      <span class="menu-emoji">🧮</span>
      <span class="menu-titulo">Simulador</span>
      <span class="menu-desc">Calcule parcelas e juros</span>
    </a>
    <a class="menu-card" href="/capacidade">
      <span class="menu-emoji">💰</span>
      <span class="menu-titulo">Capacidade</span>
      <span class="menu-desc">Quanto posso financiar?</span>
    </a>
    <a class="menu-card" href="/sobre">
      <span class="menu-emoji">👥</span>
      <span class="menu-titulo">Sobre</span>
      <span class="menu-desc">Equipe do projeto</span>
    </a>
    <a class="menu-card" href="/help">
      <span class="menu-emoji">❓</span>
      <span class="menu-titulo">Ajuda</span>
      <span class="menu-desc">Como usar o app</span>
    </a>
  </div>
</body>
</html>
