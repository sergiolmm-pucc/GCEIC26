<!DOCTYPE html>
<html lang="pt-BR">

<head>
  <meta charset="UTF-8">
  <title>Calculadora - <%= tipo %>
  </title>
  <style>
    .form-group {
      margin-bottom: 15px;
    }

    .form-group label {
      display: block;
      margin-bottom: 5px;
      font-weight: bold;
    }

    .form-group input,
    .form-group select {
      width: 100%;
      padding: 10px;
      border: 1px solid #cbd5e1;
      border-radius: 6px;
      box-sizing: border-box;
    }

    .btn-calc {
      padding: 12px 24px;
      background-color: #10b981;
      color: white;
      border: none;
      border-radius: 6px;
      cursor: pointer;
      font-size: 16px;
    }

    .btn-calc:hover {
      background-color: #059669;
    }

    .result-box {
      margin-top: 30px;
      padding: 20px;
      background-color: #dcfce7;
      border-left: 5px solid #22c55e;
      display: none;
    }

    .error-box {
      margin-top: 30px;
      padding: 20px;
      background-color: #fee2e2;
      border-left: 5px solid #ef4444;
      display: none;
      color: #b91c1c;
    }
  </style>
</head>

<body>
  <%- include('../partials/header') %>

    <div class="container">
      <h1 style="text-transform: capitalize;">Cálculo de <%= tipo %>
      </h1>

      <form id="calcForm" onsubmit="realizarCalculo(event)">

        <% if (tipo==='volume' ) { %>
          <div class="form-group">
            <label>Largura (m)</label>
            <input type="number" id="largura" required min="0" step="0.01">
          </div>
          <div class="form-group">
            <label>Comprimento (m)</label>
            <input type="number" id="comprimento" required min="0" step="0.01">
          </div>
          <div class="form-group">
            <label>Profundidade (m)</label>
            <input type="number" id="profundidade" required min="0" step="0.01">