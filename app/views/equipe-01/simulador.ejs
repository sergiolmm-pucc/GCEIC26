<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>FINV – Simulador</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: 'Inter', system-ui, sans-serif;
      background: #07090d; color: #eef1f7;
      min-height: 100dvh; -webkit-font-smoothing: antialiased;
    }
    a { color: inherit; text-decoration: none; }
    .topbar {
      position: sticky; top: 0; z-index: 100;
      display: flex; align-items: center;
      padding: 0 20px; height: 56px;
      background: rgba(7,9,13,.88);
      backdrop-filter: blur(14px); -webkit-backdrop-filter: blur(14px);
      border-bottom: 1px solid #1f2638;
    }
    .topbar-left { display: flex; align-items: center; gap: 12px; }
    .logo { font-size: 17px; font-weight: 700; letter-spacing: -.02em; }
    .btn-back {
      display: inline-flex; align-items: center; gap: 6px;
      padding: 6px 12px; border-radius: 8px;
      font-size: 13px; font-weight: 500; color: #8b94a8;
      border: 1px solid #1f2638; cursor: pointer;
      transition: color 150ms, border-color 150ms, background 150ms;
    }
    .btn-back:hover { color: #eef1f7; border-color: #2a3347; background: #111520; }
    .content {
      max-width: 600px; margin: 0 auto;
      padding: 24px 16px 48px;
      display: flex; flex-direction: column; gap: 16px;
    }
    .card {
      background: #111520; border: 1px solid #1f2638;
      border-radius: 20px; padding: 24px;
      box-shadow: 0 4px 16px rgba(0,0,0,.5);
    }
    .card-titulo {
      font-size: 15px; font-weight: 600; letter-spacing: -.01em;
      margin-bottom: 20px; padding-bottom: 14px; border-bottom: 1px solid #1f2638;
    }
    .grupo { display: flex; flex-direction: column; gap: 6px; margin-bottom: 16px; }
    .label { font-size: 13px; font-weight: 500; color: #8b94a8; }
    .input {
      width: 100%; padding: 11px 14px;
      background: #0c0f16; border: 1px solid #1f2638;
      border-radius: 8px; color: #eef1f7;
      font-family: inherit; font-size: 15px; outline: none;
      transition: border-color 150ms, box-shadow 150ms, background 150ms;
      -webkit-appearance: none; appearance: none;
    }
    .input::placeholder { color: #555e73; }
    .input:hover  { border-color: #2a3347; }
    .input:focus  { border-color: #f59e0b; background: #07090d; box-shadow: 0 0 0 3px rgba(245,158,11,.12); }
    .input[type=number]::-webkit-inner-spin-button,
    .input[type=number]::-webkit-outer-spin-button { -webkit-appearance: none; }
    .input[type=number] { -moz-appearance: textfield; }
    .linha { display: flex; gap: 12px; margin-bottom: 16px; }
    .linha .grupo { flex: 1; margin-bottom: 0; }
    .erro {
      font-size: 13px; font-weight: 500; color: #f87171;
      background: rgba(248,113,113,.1); border: 1px solid rgba(248,113,113,.2);
      border-radius: 8px; padding: 10px 14px; margin-bottom: 16px;
    }
    .btn-primary {
      display: block; width: 100%; padding: 13px; margin-top: 20px;
      background: #f59e0b; color: #0a0600;
      border: none; border-radius: 8px;
      font-family: inherit; font-size: 14px; font-weight: 700;
      letter-spacing: .06em; cursor: pointer;
      transition: filter 150ms, transform 150ms, box-shadow 150ms;
    }
    .btn-primary:hover { filter: brightness(1.08); box-shadow: 0 0 20px rgba(245,158,11,.25); transform: translateY(-1px); }
    .btn-primary:active { transform: translateY(0); }
    .btn-primary:disabled { opacity: .45; cursor: not-allowed; transform: none; box-shadow: none; filter: none; }
    #resultado { animation: fadeUp .25s ease; }
    @keyframes fadeUp { from { opacity:0; transform:translateY(8px); } to { opacity:1; transform:translateY(0); } }
    .result-linha {
      display: flex; justify-content: space-between; align-items: center;
      padding: 12px 0; border-bottom: 1px solid #1f2638;
    }
    .result-linha:last-child { border-bottom: none; padding-bottom: 0; }
    .result-label { font-size: 13px; color: #8b94a8; }
    .result-valor { font-size: 16px; font-weight: 700; color: #f59e0b; font-variant-numeric: tabular-nums; }
    @media (max-width: 480px) {
      .content { padding: 16px 12px 40px; }
      .card { padding: 18px 16px; }
      .linha { flex-direction: column; gap: 0; margin-bottom: 0; }
      .linha .grupo { margin-bottom: 16px; }
    }
  </style>
</head>
<body>
  <div class="topbar">
    <div class="topbar-left">
      <a class="btn-back" href="/equipe-01/home">← Voltar</a>
      <span class="logo">Simulador</span>
    </div>
  </div>

  <div class="content">
    <div class="card">
      <h3 class="card-titulo">Dados do Financiamento</h3>

      <div class="grupo">
        <label class="label" for="valorVeiculo">Valor do Veículo (R$)</label>
        <input class="input" type="number" id="valorVeiculo" placeholder="Ex: 60000" min="0">
      </div>

      <div class="grupo">
        <label class="label" for="entrada">Entrada (R$)</label>
        <input class="input" type="number" id="entrada" placeholder="Ex: 12000" min="0">
      </div>

      <div class="linha">
        <div class="grupo">
          <label class="label" for="taxaMensal">Taxa Mensal (%)</label>
          <input class="input" type="number" id="taxaMensal" step="0.01" value="1.29" min="0">
        </div>
        <div class="grupo">
          <label class="label" for="numParcelas">Nº Parcelas</label>
          <input class="input" type="number" id="numParcelas" value="48" min="1">
        </div>
      </div>

      <p class="erro" id="erro" style="display:none"></p>

      <button class="btn-primary" id="btnCalcular" onclick="calcular()">CALCULAR</button>
    </div>

    <div class="card" id="resultado" style="display:none">
      <h3 class="card-titulo">Resultado</h3>
      <div class="result-linha">
        <span class="result-label">Valor Financiado</span>
        <span class="result-valor" id="valorFinanciado"></span>
      </div>
      <div class="result-linha">
        <span class="result-label">Parcela Mensal</span>
        <span class="result-valor" id="parcela"></span>
      </div>
      <div class="result-linha">
        <span class="result-label">Total Pago</span>
        <span class="result-valor" id="totalPago"></span>
      </div>
      <div class="result-linha">
        <span class="result-label">Juros Totais</span>
        <span class="result-valor" id="jurosTotais"></span>
      </div>
    </div>
  </div>

  <script>
    const API_URL = 'http://localhost:3001';

    function fmt(val) {
      return Number(val).toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' });
    }

    function mostrarErro(msg) {
      const el = document.getElementById('erro');
      el.textContent = msg;
      el.style.display = 'block';
    }

    function ocultarErro() {
      document.getElementById('erro').style.display = 'none';
    }

    async function calcular() {
      ocultarErro();
      document.getElementById('resultado').style.display = 'none';

      const valorVeiculo = Number(document.getElementById('valorVeiculo').value);
      if (!valorVeiculo || valorVeiculo <= 0) {
        return mostrarErro('Informe o valor do veículo.');
      }

      const btn = document.getElementById('btnCalcular');
      btn.disabled = true;
      btn.textContent = 'Calculando...';

      try {
        const res = await fetch(`${API_URL}/api/parcela`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            valorVeiculo,
            entrada: Number(document.getElementById('entrada').value) || 0,
            taxaMensal: Number(document.getElementById('taxaMensal').value),
            numParcelas: Number(document.getElementById('numParcelas').value),
          }),
        });

        const json = await res.json();
        if (!json.success) throw new Error(json.error);

        const d = json.data;
        document.getElementById('valorFinanciado').textContent = fmt(d.valorFinanciado);
        document.getElementById('parcela').textContent = fmt(d.parcela);
        document.getElementById('totalPago').textContent = fmt(d.totalPago);
        document.getElementById('jurosTotais').textContent = fmt(d.jurosTotais);
        document.getElementById('resultado').style.display = 'block';
      } catch (e) {
        mostrarErro(e.message || 'Erro ao conectar com a API.');
      } finally {
        btn.disabled = false;
        btn.textContent = 'CALCULAR';
      }
    }
  </script>
</body>
</html>
