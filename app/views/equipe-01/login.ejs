<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>FINV – Login</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: 'Inter', system-ui, sans-serif;
      background: #07090d;
      color: #eef1f7;
      min-height: 100dvh;
      -webkit-font-smoothing: antialiased;
    }
    .login-container {
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 100dvh;
      padding: 24px 16px;
      background: radial-gradient(ellipse 55% 45% at 50% 30%, rgba(245,158,11,.05) 0%, transparent 70%);
    }
    .login-box {
      width: 100%;
      max-width: 380px;
      background: #111520;
      border: 1px solid #1f2638;
      border-radius: 20px;
      padding: 36px 28px 28px;
      box-shadow: 0 12px 40px rgba(0,0,0,.7);
    }
    .login-titulo {
      font-size: 44px;
      font-weight: 800;
      letter-spacing: -.05em;
      background: linear-gradient(135deg, #f59e0b, #fbbf24);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      text-align: center;
      margin-bottom: 4px;
    }
    .login-subtitulo {
      font-size: 14px;
      color: #8b94a8;
      text-align: center;
      margin-bottom: 28px;
    }
    .grupo { display: flex; flex-direction: column; gap: 6px; margin-bottom: 16px; }
    .label { font-size: 13px; font-weight: 500; color: #8b94a8; }
    .input {
      width: 100%;
      padding: 11px 14px;
      background: #0c0f16;
      border: 1px solid #1f2638;
      border-radius: 8px;
      color: #eef1f7;
      font-family: inherit;
      font-size: 15px;
      outline: none;
      transition: border-color 150ms, box-shadow 150ms, background 150ms;
      -webkit-appearance: none;
    }
    .input::placeholder { color: #555e73; }
    .input:hover  { border-color: #2a3347; }
    .input:focus  { border-color: #f59e0b; background: #07090d; box-shadow: 0 0 0 3px rgba(245,158,11,.12); }
    .btn-primary {
      display: block;
      width: 100%;
      padding: 13px;
      margin-top: 20px;
      background: #f59e0b;
      color: #0a0600;
      border: none;
      border-radius: 8px;
      font-family: inherit;
      font-size: 14px;
      font-weight: 700;
      letter-spacing: .06em;
      cursor: pointer;
      transition: filter 150ms, transform 150ms, box-shadow 150ms;
    }
    .btn-primary:hover {
      filter: brightness(1.08);
      box-shadow: 0 0 20px rgba(245,158,11,.25);
      transform: translateY(-1px);
    }
    .btn-primary:active { transform: translateY(0); }
    .login-dica {
      font-size: 12px;
      color: #555e73;
      text-align: center;
      margin-top: 18px;
      font-family: 'JetBrains Mono', monospace;
      background: #0c0f16;
      border: 1px solid #1f2638;
      border-radius: 8px;
      padding: 8px 12px;
    }
    #erro { margin-top: 12px; font-size: 13px; }
  </style>
</head>
<body>
  <div class="login-container">
    <div class="login-box">
      <h1 class="login-titulo">FINV</h1>
      <p class="login-subtitulo">Financiamento de Veículos</p>

      <div class="grupo">
        <label class="label" for="username">Usuário</label>
        <input class="input" type="text" id="username"
          placeholder="Digite seu usuário" autocomplete="username" required>
      </div>

      <div class="grupo">
        <label class="label" for="password">Senha</label>
        <input class="input" type="password" id="password"
          placeholder="Digite sua senha" autocomplete="current-password" required>
      </div>

      <p id="erro" style="color: red; display: none;">Usuário ou senha inválidos</p>

      <button class="btn-primary" onclick="login()">ENTRAR</button>

      <p class="login-dica">usuário: admin · senha: 1234</p>
    </div>
  </div>

  <script>
    function login() {
      const username = document.getElementById('username').value;
      const password = document.getElementById('password').value;

      if (username === 'admin' && password === '1234') {
        window.location.href = '/equipe-01/home';
      } else {
        document.getElementById('erro').style.display = 'block';
      }
    }
  </script>
</body>
</html>