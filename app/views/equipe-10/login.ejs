<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <title>Login</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <h2>Login</h2>
    <% if (typeof erro !== 'undefined' && erro) { %><p style="color:red;"><%= erro %></p><% } %>
    <form action="/equipe-10/login" method="POST">
        <input type="text" name="username" placeholder="admin" required><br>
        <input type="password" name="password" placeholder="1234" required><br>
        <button type="submit">Entrar</button>
    </form>
</body>
</html>