<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Água - Calculadora de Consumo</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Segoe UI', sans-serif;
      background: linear-gradient(135deg, #0077b6, #00b4d8, #90e0ef);
      min-height: 100vh;
      display: flex; flex-direction: column;
      align-items: center; justify-content: center;
      color: #fff;
    }
    .splash-icon { font-size: 5rem; margin-bottom: 1rem; animation: pulse 2s infinite; }
    @keyframes pulse { 0%,100%{transform:scale(1)} 50%{transform:scale(1.1)} }
    h1 { font-size: 2.5rem; font-weight: 700; margin-bottom: 0.5rem; }
    p  { font-size: 1.1rem; opacity: 0.85; margin-bottom: 2.5rem; }
    .btn {
      background: #fff; color: #0077b6;
      border: none; border-radius: 30px;
      padding: 14px 40px; font-size: 1.1rem;
      font-weight: 600; cursor: pointer;
      text-decoration: none;
      transition: transform 0.2s, box-shadow 0.2s;
      box-shadow: 0 4px 20px rgba(0,0,0,0.15);
    }
    .btn:hover { transform: translateY(-2px); box-shadow: 0 8px 30px rgba(0,0,0,0.2); }
    .versao { margin-top: 2rem; font-size: 0.8rem; opacity: 0.6; }
  </style>
</head>
<body>
  <div class="splash-icon">💧</div>
  <h1>AguaCalc</h1>
  <p>Calculadora de Consumo de Água Residencial</p>
  <a class="btn" href="/login">Entrar no sistema</a>
  <span class="versao">v1.0 — GCEIC26</span>
</body>
</html>
