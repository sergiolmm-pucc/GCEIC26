<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login — SaunaCalc Elite</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
      background: #f0f2f5;
      font-family: 'Segoe UI', sans-serif;
    }
    .card {
      background: white;
      padding: 2.5rem;
      border-radius: 16px;
      width: 360px;
      box-shadow: 0 8px 32px rgba(0,0,0,0.1);
    }
    .logo { text-align: center; font-size: 2.5rem; margin-bottom: 0.5rem; }
    h2 { text-align: center; color: #1a1a2e; margin-bottom: 1.8rem; font-size: 1.3rem; }
    label { display: block; font-size: 0.85rem; color: #555; margin-bottom: 0.3rem; }
    input {
      width: 100%; padding: 0.75rem 1rem;
      border: 1.5px solid #ddd; border-radius: 8px;
      font-size: 1rem; margin-bottom: 1rem;
      transition: border-color 0.2s;
    }
    input:focus { outline: none; border-color: #e74c3c; }
    button {
      width: 100%; padding: 0.85rem;
      background: #e74c3c; color: white;
      border: none; border-radius: 8px;
      font-size: 1rem; font-weight: 600;
      cursor: pointer; transition: background 0.2s;
    }
    button:hover { background: #c0392b; }
    .erro { color: #e74c3c; font-size: 0.9rem; margin-bottom: 0.8rem; }
    .hint { text-align: center; margin-top: 1rem; font-size: 0.78rem; color: #aaa; }
  </style>
</head>
<body>
  <div class="card">
    <div class="logo">🧖</div>
    <h2>SaunaCalc Elite</h2>

    <% if (typeof erro !== 'undefined' && erro) { %>
      <p class="erro">⚠️ <%= erro %></p>
    <% } %>

    <form action="/equipe-22/login" method="POST">
      <label>Usuário</label>
      <input type="text" name="usuario" placeholder="Digite seu usuário" required>

      <label>Senha</label>
      <input type="password" name="senha" placeholder="Digite sua senha" required>

      <button type="submit">Entrar</button>
    </form>

    <p class="hint">usuário: <b>admin</b> &nbsp;|&nbsp; senha: <b>123</b></p>
  </div>
</body>
</html>