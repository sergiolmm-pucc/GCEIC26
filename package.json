{
  "name": "simulador-preco-bruto-liquido",
  "version": "1.0.0",
  "private": true,
  "description": "Projeto acadêmico CI/CD: API Node e app React para simular preço bruto e líquido.",
  "workspaces": [
    "api",
    "app"
  ],
  "scripts": {
    "dev": "npm run dev --workspace api",
    "dev:api": "npm run dev --workspace api",
    "dev:app": "npm run dev --workspace app",
    "test": "npm run test --workspaces --if-present",
    "test:api": "npm run test --workspace api",
    "test:app": "npm run test --workspace app",
    "build": "npm run build --workspace app"
  }
}
