{
  "version": 2,
  "builds": [
    {
      "src": "api/api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "web/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/PBL(?:/(.*))?",
      "dest": "/api/api/index.js"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/web/index.html"
    }
  ]
}
