{
  "name": "gceic",
  "version": "1.0.0",
  "description": "API para calculo de MarkUp",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "test": "jest --coverage --verbose --ci --reporters=default --reporters=jest-junit",
    "dev": "tsx watch src/equipe-18/server.ts",
    "build": "tsc",
    "test:vitest": "vitest run",
    "lint": "biome check src",
    "format": "biome format src --write"
  },
  "keywords": [
    "teste",
    "CI",
    "CD"
  ],
  "author": "SLMM",
  "license": "ISC",
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.6",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "fastify": "^5.8.5",
    "fastify-plugin": "^5.1.0",
    "fastify-type-provider-zod": "^6.1.0",
    "helmet": "^8.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@types/node": "^25.9.0",
    "jest": "^29.7.0",
    "jest-junit": "^16.0.0",
    "supertest": "^7.2.2",
    "tsx": "^4.22.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "jest": {
    "testMatch": [
      "<rootDir>/tests/**/*.test.js"
    ]
  }
